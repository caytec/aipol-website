# AiPol — konfiguracja Apache/LiteSpeed dla statycznego frontu
# Plik kopiowany przez Vite do dist/ podczas build.

# Wymuszenie HTTPS (odkomentuj po wpięciu certyfikatu)
# RewriteEngine On
# RewriteCond %{HTTPS} off
# RewriteRule ^(.*)$ https://%{HTTP_HOST}/$1 [R=301,L]

# Kompresja
<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/css text/javascript application/javascript application/json image/svg+xml
</IfModule>

# Cache assetów (Vite hashuje nazwy plików => bezpieczne na rok)
<IfModule mod_headers.c>
  <FilesMatch "\.(js|css|woff2?|ttf|eot|svg|png|jpg|jpeg|webp|gif|ico)$">
    Header set Cache-Control "public, max-age=31536000, immutable"
  </FilesMatch>
  <FilesMatch "^index\.html$">
    Header set Cache-Control "no-cache, no-store, must-revalidate"
  </FilesMatch>
</IfModule>

# Domyślny dokument
DirectoryIndex index.html

# Strona używa wyłącznie kotwic (#services, #contact, ...) — brak SPA route'ów,
# więc nie ma fallbacka do index.html. Pliki niewidoczne -> 404.

# Twarda blokada katalogów konfiguracyjnych
<FilesMatch "(^\.|\.sql$|\.md$)">
  Require all denied
</FilesMatch>
